# ─────────────────────────────────────────────
# Code4Care / Room 1221 — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# ─────────────────────────────────────────────

# App environment: development | staging | production
VITE_ENV=development

# Backend API base URL (provided by backend team)
VITE_API_BASE_URL=https://code4care-backend-production.up.railway.app

# Feature flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CONSULTANT_MODE=false
VITE_ENABLE_ADMIN=false

# Optional: Sentry DSN for error monitoring (production only)
VITE_SENTRY_DSN=
